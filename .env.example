# ── Shared ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── S3 ────────────────────────────────────────────────────────────────────────
# Main bucket for documents, prompts, schemas and results
DOCUMENTS_BUCKET=your-documents-bucket-name
DOC_BUCKET=your-documents-bucket-name        # alias used by createFundUpload & icMemoExtraction
BUCKET_NAME=your-documents-bucket-name       # alias used by fundUploadComplete

# ── DynamoDB ──────────────────────────────────────────────────────────────────
# All functions point to the same table; env var name differs per function
DDB_TABLE=your-funds-table-name              # createFundUpload, icMemoExtraction
DDB_TABLE_NAME=your-funds-table-name         # fundInitUpload, fundDocumentProcessor, fundProcessingStatus
DYNAMODB_TABLE=your-funds-table-name         # fundDocumentUpload, fundUploadComplete, fundGetById

# ── SQS ───────────────────────────────────────────────────────────────────────
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/your-processing-queue
SUCCESS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/your-success-queue

# ── Bedrock ───────────────────────────────────────────────────────────────────
# Rules Engine flow (fundDocumentProcessor)
NOVA_MODEL_ID=amazon.nova-pro-v1:0
PROMPT_S3_URI=s3://your-documents-bucket-name/prompts/rules-engine-prompt.txt

# IC Memo flow (icMemoExtraction)
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
PROMPT_KEY=prompts/ic-memo-system-prompt.txt
SCHEMA_KEY=prompts/ic-memo-schema.json

# ── Presigned URL ─────────────────────────────────────────────────────────────
PRESIGN_EXPIRES_SECONDS=900

# ── Optional ──────────────────────────────────────────────────────────────────
RECORD_TTL_DAYS=30
